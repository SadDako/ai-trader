# Copy this file to .env and fill values locally. Never commit .env.

ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Dashboard/API exposure. Localhost is the secure default.
WEB_HOST=127.0.0.1
WEB_PORT=3000

# Recommended when WEB_HOST is exposed outside localhost.
DASHBOARD_AUTH_TOKEN=your-dashboard-token-here

# Only use true for isolated local development.
DISABLE_DASHBOARD_AUTH=false
